# .env — TidyBot ROS 2 environment reference
# ============================================
# This file documents the exact environment variables active during
# development. It is NOT sourced automatically.
#
# To apply: source setup_env.sh
# Or manually add to ~/.bashrc:
#   source /opt/ros/humble/setup.bash
#   source ~/tidybot_ws/install/setup.bash
#   export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

ROS_DISTRO=humble
ROS_VERSION=2
ROS_PYTHON_VERSION=3
ROS_LOCALHOST_ONLY=0

RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Paths below are relative to the install location — shown here for reference.
# Automatically set by sourcing setup.bash; do NOT hard-code in scripts.
#
# AMENT_PREFIX_PATH=<ws>/install/tidybot_bringup:<ws>/install/...:/opt/ros/humble
# COLCON_PREFIX_PATH=<ws>/install
# PYTHONPATH=<ws>/install/tidybot_behavior/lib/python3.10/site-packages:/opt/ros/humble/lib/python3.10/site-packages:/opt/ros/humble/local/lib/python3.10/dist-packages
# LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/gazebo-11/plugins:/opt/ros/humble/opt/rviz_ogre_vendor/lib:/opt/ros/humble/lib/x86_64-linux-gnu:/opt/ros/humble/lib
